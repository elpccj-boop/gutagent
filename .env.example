# Auth
GUTAGENT_USERNAME=your_username
GUTAGENT_PASSWORD=your_password

# LLM Provider (uncomment one)
#LLM_PROVIDER=claude
#LLM_PROVIDER=gemini
#LLM_PROVIDER=openai

# API Keys (only need the one for your chosen provider)
#ANTHROPIC_API_KEY=sk-ant-...
#GEMINI_API_KEY=...
#OPENAI_API_KEY=sk-...

# Claude Cache TTL. Default is 5 minutes. Set to "1h" for 1-hour cache.
#CLAUDE_CACHE_TTL=1h

# Logging: DEBUG, INFO, WARNING (default), ERROR, CRITICAL
GUTAGENT_LOG_LEVEL=WARNING

# Database paths (optional - defaults to ./data/)
#GUTAGENT_DB_PATH=./data/gutagent.db
#GUTAGENT_PROFILE_PATH=./data/profile.json

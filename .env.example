# Auth
GUTAGENT_USERNAME=your_username
GUTAGENT_PASSWORD=your_password

# LLM Provider (uncomment one)
# LLM_PROVIDER=claude
# LLM_PROVIDER=openai
# LLM_PROVIDER=ollama
# LLM_PROVIDER=groq
# LLM_PROVIDER=gemini

# API Keys (only need the one for your chosen provider)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# GOOGLE_API_KEY=...

# Options: DEBUG, INFO, WARNING (default), ERROR, CRITICAL
GUTAGENT_LOG_LEVEL=WARNING
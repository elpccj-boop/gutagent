# ============================================================
# GutAgent Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# There are TWO server modes:
#   1. Web UI (server.py)  - Full agent loop on server, uses API keys below
#   2. Mobile API (mobile.py) - LLM proxy only, users provide their own keys
# ============================================================

# ------------------------------------------------------------
# WEB UI SERVER (gutagent-web / server.py)
# ------------------------------------------------------------
# Basic auth for web UI (optional - skip for local development)
#GUTAGENT_USERNAME=your_username
#GUTAGENT_PASSWORD=your_password

# LLM Provider for web UI
#LLM_PROVIDER=claude
#LLM_PROVIDER=gemini
#LLM_PROVIDER=openai

# API Keys for web UI (only need the one for your chosen provider)
#ANTHROPIC_API_KEY=sk-ant-...
#GEMINI_API_KEY=...
#OPENAI_API_KEY=sk-...

# Claude cache TTL (default: 5 minutes, use "1h" for 1-hour cache)
#CLAUDE_CACHE_TTL=1h

# Logging level: DEBUG, INFO, WARNING (default), ERROR, CRITICAL
GUTAGENT_LOG_LEVEL=WARNING

# Database paths (optional - defaults to ./data/)
#GUTAGENT_DB_PATH=./data/gutagent.db
#GUTAGENT_PROFILE_PATH=./data/profile.json

# ------------------------------------------------------------
# MOBILE API SERVER (gutagent-mobile-api / mobile.py)
# ------------------------------------------------------------
# REQUIRED for production - generate once and keep secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here

# REQUIRED for production - generate once and keep secret:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# Mobile users database (default: ./data/mobile_users.db)
#MOBILE_DB_PATH=./data/mobile_users.db

# Note: Mobile users provide their own LLM API keys via the app.
# The server encrypts and stores them using ENCRYPTION_KEY above.